{
  "expo": {
    "name": "Sequence Trip",
    "slug": "sequence-trip",
    "version": "1.5.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sequencetrip",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#07060E"
    },
    "android": {
      "package": "dev.stimmie.oeisvisualizations",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#07060E"
      },
      "versionCode": 15
    },
    "ios": {
      "bundleIdentifier": "dev.stimmie.oeisvisualizations",
      "supportsTablet": true
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static",
      "backgroundColor": "#07060E",
      "name": "Sequence Trip",
      "shortName": "SeqTrip",
      "description": "Visualize 397k+ OEIS sequences and play a new number puzzle every day.",
      "themeColor": "#07060E",
      "lang": "en"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "36.0.0"
          }
        }
      ],
      "expo-sqlite",
      "expo-audio",
      [
        "expo-notifications",
        {
          "color": "#07060E"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SequenceOfDay",
              "label": "Sequence of the Day",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "targetCellWidth": 3,
              "targetCellHeight": 2,
              "description": "Today's OEIS sequence",
              "previewImage": "./assets/widget-preview.png",
              "updatePeriodMillis": 21600000
            }
          ]
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "28780a86-7afa-41d4-ba7b-6b0cd6c8e730"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/28780a86-7afa-41d4-ba7b-6b0cd6c8e730"
    }
  }
}
